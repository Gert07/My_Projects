Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# Route /api/todos and /api/todos/123 to the PHP handler
RewriteRule ^api/todos(/[0-9]+)?$ api/todos.php [QSA,L]

# Route /api/gallery routes to the PHP handler
RewriteRule ^api/gallery/categories/([^/]+)$ api/gallery.php [QSA,L]
RewriteRule ^api/gallery/categories$ api/gallery.php [QSA,L]
RewriteRule ^api/gallery(/[0-9]+)?$ api/gallery.php [QSA,L]

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpg                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
